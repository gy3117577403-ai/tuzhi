CONNECTOR_AI_API_BASE_URL=
CONNECTOR_AI_API_KEY=
CONNECTOR_AI_MODEL=
CONNECTOR_AI_PROVIDER=openai_compatible
CONNECTOR_CAD_API_KEY=
AUDIT_SIGNING_SECRET=change-me-in-production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Image search providers:
# - mock: local deterministic test image
# - serpapi: SerpAPI image search
# - bing: Bing Image Search-compatible endpoint
# - generic_json: generic JSON image search endpoint
# - manual_url: no server-side search; paste an image URL in the UI
# Keys must never be committed.
IMAGE_SEARCH_PROVIDER=mock
IMAGE_SEARCH_API_KEY=
IMAGE_SEARCH_BASE_URL=
IMAGE_SEARCH_ENDPOINT=
IMAGE_SEARCH_MAX_RESULTS=8
IMAGE_SEARCH_SAFE_MODE=true
IMAGE_SEARCH_MARKET=zh-CN
IMAGE_SEARCH_TIMEOUT_SECONDS=15
IMAGE_SEARCH_ENABLE_CANDIDATE_PROBING=true

# Procurement search providers only support mock data, manual imports, official open platforms,
# enterprise-authorized APIs, or supplier-authorized APIs. Do not use this app for unauthorized scraping.
PROCUREMENT_GENERIC_JSON_BASE_URL=
PROCUREMENT_GENERIC_JSON_API_KEY=
PROCUREMENT_GENERIC_JSON_AUTH_HEADER=Authorization

# Procurement SerpAPI search summary provider.
# Uses search engine summaries only; does not crawl protected platform detail pages.
PROCUREMENT_SEARCH_PROVIDER=
PROCUREMENT_SERPAPI_API_KEY=
PROCUREMENT_SERPAPI_BASE_URL=https://serpapi.com/search.json
PROCUREMENT_SERPAPI_MAX_RESULTS=12
PROCUREMENT_SERPAPI_LOCATION=China
PROCUREMENT_SERPAPI_GL=cn
PROCUREMENT_SERPAPI_HL=zh-cn
PROCUREMENT_ENABLE_SERPAPI_SHOPPING=true
PROCUREMENT_ENABLE_SERPAPI_SITE_SEARCH=true
PROCUREMENT_SITE_SEARCH_DOMAINS=taobao.com,jd.com,1688.com
