CONNECTOR_AI_API_BASE_URL=
CONNECTOR_AI_API_KEY=
CONNECTOR_AI_MODEL=
CONNECTOR_AI_PROVIDER=openai_compatible
CONNECTOR_CAD_API_KEY=
AUDIT_SIGNING_SECRET=change-me-in-production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Image search providers:
# - mock: local deterministic test image
# - serpapi: SerpAPI image search
# - bing: Bing Image Search-compatible endpoint
# - generic_json: generic JSON image search endpoint
# - manual_url: no server-side search; paste an image URL in the UI
# Keys must never be committed.
IMAGE_SEARCH_PROVIDER=mock
IMAGE_SEARCH_API_KEY=
IMAGE_SEARCH_BASE_URL=
IMAGE_SEARCH_ENDPOINT=
IMAGE_SEARCH_MAX_RESULTS=8
IMAGE_SEARCH_SAFE_MODE=true
IMAGE_SEARCH_MARKET=zh-CN
IMAGE_SEARCH_TIMEOUT_SECONDS=15
IMAGE_SEARCH_ENABLE_CANDIDATE_PROBING=true
